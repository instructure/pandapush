# Pandapush Smoke Tests Configuration
#
# Copy to .env and fill in values for your target environment.
# For local docker compose, the defaults below should work as-is.

# Base URL of the Pandapush instance
# For local docker compose, run with:
#   docker compose -f local-compose.yml -f local-compose.smoke-test.yml up
SMOKE_TEST_BASE_URL=http://localhost:3000

# Pre-provisioned application credentials
SMOKE_TEST_APP_ID=devapp
SMOKE_TEST_KEY_ID=devkey
SMOKE_TEST_KEY_SECRET=devsecret

# Environment identifier: local | dev | beta | prod
SMOKE_TEST_ENVIRONMENT=local

# Admin API credentials (docker compose only — Okta envs don't support this)
SMOKE_TEST_ADMIN_USERNAME=admin
SMOKE_TEST_ADMIN_PASSWORD=password
